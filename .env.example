# Supabase (required for API serverless functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase anon key (required for frontend uploads; expose via Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin password (do not hardcode; required for /admin/inventory)
ADMIN_PASSWORD=your-secure-password

# Optional: add these in Vercel project settings (not in .env for local)
# ADMIN_PASSWORD is set in Vercel Environment Variables
